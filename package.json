{
  "name": "falcon",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade multi-tenant Automotive Operating System for dealerships.",
  "type": "module",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @falcon/frontend --filter @falcon/backend dev",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm --filter @falcon/backend test && corepack pnpm --filter @falcon/frontend test",
    "test:backend": "corepack pnpm --filter @falcon/backend test",
    "test:frontend": "corepack pnpm --filter @falcon/frontend test",
    "typecheck": "corepack pnpm -r typecheck",
    "prisma:generate": "corepack pnpm --filter @falcon/backend prisma:generate",
    "prisma:push": "corepack pnpm --filter @falcon/backend prisma:push",
    "seed": "corepack pnpm --filter @falcon/backend seed",
    "format": "prettier --write ."
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}

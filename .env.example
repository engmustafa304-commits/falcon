# Shared
NODE_ENV=development

# Frontend
VITE_APP_NAME=Falcon
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_PUBLIC_SITE_URL=http://localhost:3000

# Backend
PORT=4000
DATABASE_URL="file:./dev.db"
DATABASE_URL_STAGING="postgresql://USER:PASSWORD@HOST:5432/falcon_staging?sslmode=require"
JWT_ACCESS_SECRET="replace-with-a-secure-access-secret"
JWT_REFRESH_SECRET="replace-with-a-secure-refresh-secret"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Storage and integrations
STORAGE_PROVIDER=local
PUBLIC_UPLOAD_BASE_URL=http://localhost:4000/uploads
STAGING_SUPER_ADMIN_EMAIL=
STAGING_SUPER_ADMIN_PASSWORD=
STAGING_SUPER_ADMIN_NAME=Falcon Staging Owner
STAGING_SUPER_ADMIN_TENANT_ID=platform
UPLOADS_DIR=apps/backend/uploads
WHATSAPP_PROVIDER=
PAYMENT_PROVIDER=

NODE_ENV=staging
PORT=4000
# Railway/managed runtime should use DATABASE_URL directly from Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/falcon_staging?schema=public&sslmode=require"

# Local staging scripts may use DATABASE_URL_STAGING and map it to DATABASE_URL before Prisma initializes.
DATABASE_URL_STAGING="postgresql://USER:PASSWORD@HOST:5432/falcon_staging?schema=public&sslmode=require"
JWT_ACCESS_SECRET="replace-with-a-long-random-staging-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-staging-refresh-secret"
CORS_ORIGINS="https://staging.falcon.example.com"
FRONTEND_URL=https://staging.falcon.example.com
API_PUBLIC_URL=https://staging-api.falcon.example.com
STORAGE_PROVIDER=cloudinary
PUBLIC_UPLOAD_BASE_URL=https://staging-api.falcon.example.com/uploads
CLOUDINARY_CLOUD_NAME="replace-with-staging-cloud-name"
CLOUDINARY_API_KEY="replace-with-staging-api-key"
CLOUDINARY_API_SECRET="replace-with-staging-api-secret"
CLOUDINARY_FOLDER=falcon/staging/cars

# Staging seed credentials are required only when running the seed script.
STAGING_SUPER_ADMIN_EMAIL="engmustafa304@gmail.com"
STAGING_SUPER_ADMIN_PASSWORD="replace-with-a-one-time-strong-staging-password"
STAGING_SUPER_ADMIN_NAME="Falcon Staging Owner"
STAGING_SUPER_ADMIN_TENANT_ID="platform"

# Cloudinary is the recommended staging image provider.
# Keep these values in a secret manager, not in source control.

NODE_ENV=production
PORT=4000
DATABASE_URL="postgresql://falcon_user:replace-password@postgres.example.com:5432/falcon?schema=public"
JWT_ACCESS_SECRET="replace-with-a-long-random-production-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-production-refresh-secret"
CORS_ORIGINS="https://falcon.example.com,https://www.falcon.example.com"
FRONTEND_URL=https://falcon.example.com
API_PUBLIC_URL=https://api.falcon.example.com
STORAGE_PROVIDER=cloudinary
PUBLIC_UPLOAD_BASE_URL=https://api.falcon.example.com/uploads
CLOUDINARY_CLOUD_NAME="replace-with-production-cloud-name"
CLOUDINARY_API_KEY="replace-with-production-api-key"
CLOUDINARY_API_SECRET="replace-with-production-api-secret"
CLOUDINARY_FOLDER=falcon/production/cars
SEED_SUPER_ADMIN_EMAIL="owner@falcon.example.com"
SEED_SUPER_ADMIN_PASSWORD="replace-with-a-one-time-strong-password"
SEED_SUPER_ADMIN_NAME="Falcon Owner"
SEED_SUPER_ADMIN_TENANT_ID="platform"

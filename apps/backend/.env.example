NODE_ENV=development
PORT=4000
DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="replace-with-a-secure-access-secret"
JWT_REFRESH_SECRET="replace-with-a-secure-refresh-secret"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
STORAGE_PROVIDER=local
PUBLIC_UPLOAD_BASE_URL=http://localhost:4000/uploads

# Optional local Cloudinary testing:
# Set STORAGE_PROVIDER=cloudinary in apps/backend/.env and fill these values locally.
# Keep secrets out of source control and never paste them into example files.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=falcon/staging/cars

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && corepack pnpm --filter @falcon/frontend build",
  "framework": "vite",
  "installCommand": "cd ../.. && corepack pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "destination": "/index.html",
      "source": "/((?!assets/|images/|fonts/|robots.txt|sitemap.xml|favicon.ico).*)"
    }
  ]
}
